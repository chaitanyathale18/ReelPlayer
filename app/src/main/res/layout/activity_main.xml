<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- Logo / Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶"
            android:textSize="64sp"
            android:textColor="#FF1744"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ReelPlayer"
            android:textSize="32sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YouTube in the background"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginBottom="48dp"/>

        <!-- Permission warning -->
        <Button
            android:id="@+id/permission_btn"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="⚠  Grant Overlay Permission"
            android:textColor="#FFFFFF"
            android:backgroundTint="#B71C1C"
            android:layout_marginBottom="16dp"
            android:textSize="14sp"
            android:visibility="visible"/>

        <!-- URL input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="YouTube URL (optional)"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/url_input"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="https://youtube.com/watch?v=..."
            android:hintTextColor="#555555"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:inputType="textUri"
            android:padding="14dp"
            android:background="@drawable/input_bg"
            android:layout_marginBottom="20dp"/>

        <!-- Play button -->
        <Button
            android:id="@+id/play_btn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="▶   Launch Background Player"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#FF1744"
            android:layout_marginBottom="40dp"/>

        <!-- How to use -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="How to use"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="14dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1. Grant overlay permission above"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2. Paste a YouTube URL or leave blank for YouTube home"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3. Tap Launch — YouTube opens as a floating overlay"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4. Start playing a video, then tap the ▶ button to dim the screen to black — audio continues!"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5. Triple-tap the ▶ button to fully exit"
                android:textColor="#CCCCCC"
                android:textSize="13sp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
